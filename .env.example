# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/otica_nina

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=otica-nina-photos
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Meta WhatsApp Cloud API
META_WA_PHONE_NUMBER_ID=your-phone-number-id
META_WA_TOKEN=your-permanent-token
META_WA_VERIFY_TOKEN=your-webhook-verify-token

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
